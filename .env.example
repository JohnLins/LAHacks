SECRET_KEY=change-me
DATABASE_URL=sqlite:///marketplace.db

# Comma-separated frontend origins allowed to call the backend with cookies.
FRONTEND_ORIGINS=http://localhost:3000

# For same-origin local dev, keep these defaults.
# For separate HTTPS frontend/backend hosting, use:
# SESSION_COOKIE_SAMESITE=None
# SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

WORLD_ID_APP_ID=
WORLD_ID_RP_ID=
WORLD_ID_ACTION=verify-account
WORLD_ID_ENVIRONMENT=production
WORLD_ID_SIGNING_KEY=
