# Hosted Flask API (Railway). Requests go directly here; /api dev proxy is unused when this is set.
REACT_APP_API_BASE_URL=https://lahacksbackend-production.up.railway.app

# Local Flask instead: leave API base empty and point the dev proxy at your server.
# REACT_APP_API_BASE_URL=
# REACT_APP_API_PROXY_TARGET=http://localhost:5000
